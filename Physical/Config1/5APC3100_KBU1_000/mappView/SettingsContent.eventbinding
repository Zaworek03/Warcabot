<?xml version="1.0" encoding="utf-8"?>
<EventBindingSet id="SettingsContent" xmlns="http://www.br-automation.com/iat2014/eventbinding/v2" xmlns:types="http://www.br-automation.com/iat2015/widgetTypes/v2" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <Bindings>
    <EventBinding id="ContentAdmin.BtnUserAdd.Click">
      <Source xsi:type="widgets.brease.Button.Event" contentRefId="SettingsContent" widgetRefId="BtnUserAdd" event="Click" />
      <EventHandler>
        <Action>
          <Target xsi:type="widgets.brease.UserList.Action" contentRefId="SettingsContent" widgetRefId="UserList">
            <Method xsi:type="widgets.brease.UserList.Action.OpenAddUserDialog" />
          </Target>
        </Action>
      </EventHandler>
    </EventBinding>
    <EventBinding id="ContentAdmin.BtnUserRemove.Click">
      <Source xsi:type="widgets.brease.Button.Event" contentRefId="SettingsContent" widgetRefId="BtnUserRemove" event="Click" />
      <EventHandler>
        <Action>
          <Target xsi:type="widgets.brease.UserList.Action" contentRefId="SettingsContent" widgetRefId="UserList">
            <Method xsi:type="widgets.brease.UserList.Action.DeleteUser" />
          </Target>
        </Action>
      </EventHandler>
    </EventBinding>
    <EventBinding id="ContentAdmin.BtnUserModify.Click">
      <Source xsi:type="widgets.brease.Button.Event" contentRefId="SettingsContent" widgetRefId="BtnUserModify" event="Click" />
      <EventHandler>
        <Action>
          <Target xsi:type="widgets.brease.UserList.Action" contentRefId="SettingsContent" widgetRefId="UserList">
            <Method xsi:type="widgets.brease.UserList.Action.OpenModifyUserDialog" />
          </Target>
        </Action>
      </EventHandler>
    </EventBinding>
  </Bindings>
</EventBindingSet>